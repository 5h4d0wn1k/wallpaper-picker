# =============================================================================
# Main entry point
# =============================================================================

main() {
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) cmd_help; exit 0 ;;
            -v|--version) echo "wallpaper-picker v${SCRIPT_VERSION}"; exit 0 ;;
            -m|--monitor) MONITOR="$2"; shift 2 ;;
            -d|--dir) DEFAULT_WALLPAPER_DIR="$2"; shift 2 ;;
            -*) echo -e "${ERROR}Unknown option:${C_RESET} $1"; exit 1 ;;
            *) break ;;
        esac
    done
    
    # Load configuration
    load_config
    
    # Parse command
    local command="${1:-}"
    shift
    
    case "$command" in
        pick)           cmd_pick ;;
        gui)            cmd_gui ;;
        browse)         cmd_browse ;;
        random)         cmd_random ;;
        smart-random)   cmd_smart_random ;;
        time-based)     cmd_time_based ;;
        slideshow)      cmd_slideshow "${1:-}" ;;
        stop)           cmd_stop ;;
        current)        cmd_current ;;
        next)           cmd_next ;;
        prev)           cmd_prev ;;
        list)           cmd_list ;;
        add-dir)        cmd_add_dir "${1:-}" ;;
        remove-dir)     cmd_remove_dir "${1:-}" ;;
        watch-dirs)     cmd_watch_dirs ;;
        toggle-fav)     cmd_toggle_fav "${1:-}" ;;
        config)         cmd_config ;;
        monitors)       cmd_monitors ;;
        monitor-info)   cmd_monitor_detailed ;;
        span)           cmd_span "${1:-}" "${2:-scaled}" ;;
        all)            cmd_all_monitors "${1:-}" "${2:-scaled}" ;;
        status)         cmd_status ;;
        doctor)         cmd_doctor ;;
        enable-startup) cmd_enable_startup ;;
        disable-startup) cmd_disable_startup ;;
        install-gui)    cmd_install_gui ;;
        preview)        cmd_preview "${1:-}" ;;
        pywal)          cmd_pywal ;;
        restore)        restore_wallpaper ;;
        set-monitor)    cmd_set_monitor "${1:-}" "${2:-}" ;;
        set)            set_wallpaper_from_stdin ;;
        help|"")        cmd_help ;;
        *)              echo -e "${ERROR}Unknown command:${C_RESET} $command"; cmd_help; exit 1 ;;
    esac
}

# Run
main "$@"

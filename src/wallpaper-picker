# =============================================================================
# Wallpaper functions
# =============================================================================

kill_wallpaper() {
    local monitor="${1:-$(resolve_monitor)}"
    
    if pgrep -f "mpvpaper.*${monitor}" >/dev/null 2>&1; then
        pkill -f "mpvpaper.*${monitor}" 2>/dev/null || true
        sleep 0.2
    fi
}

set_wallpaper() {
    local video="$1"
    local monitor
    monitor=$(resolve_monitor)
    
    # Validate video exists
    if [[ ! -f "$video" ]]; then
        echo -e "${ERROR}Error:${C_RESET} File not found: ${video}"
        return 1
    fi
    
    # Kill existing
    kill_wallpaper "$monitor"
    
    # Build options
    local audio_opts=""
    [[ "${ENABLE_AUDIO}" != "yes" ]] && audio_opts="no-audio"
    
    # Start new wallpaper
    mpvpaper -fp -o "loop-file=${LOOP_MODE} ${audio_opts} video-latency-hacks=yes" \
        "$monitor" "$video" &>/dev/null &
    
    CURRENT_WALLPAPER="$video"
    save_state
    add_to_history "$video"
    
    local filename
    filename=$(basename "$video")
    echo -e "${SUCCESS} Wallpaper set: ${C_BOLD}${filename}${C_RESET}"
    
    # Notify
    if [[ "${NOTIFICATIONS_ENABLED}" == "yes" ]]; then
        notify-send "Wallpaper" "Set: ${filename}" -t 2000 2>/dev/null || true
    fi
    
    return 0
}

get_current_wallpaper() {
    # Try running process
    local current
    current=$(pgrep -a mpvpaper 2>/dev/null | grep -oE "[^ ]+\.(mp4|webm|mkv)" | head -1 || true)
    
    # Try state file
    if [[ -z "$current" ]] && [[ -f "${STATE_FILE}" ]]; then
        current=$(grep -oE '"current":\s*"[^"]+"' "${STATE_FILE}" 2>/dev/null | \
            sed 's/"current":\s*"//;s/"$//' || true)
    fi
    
    echo "$current"
}

get_random_wallpaper() {
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo ""
        return 1
    fi
    
    local random_index=$((RANDOM % ${#videos[@]}))
    echo "${videos[$random_index]}"
}

# =============================================================================
# Video discovery
# =============================================================================

get_all_videos() {
    local videos=()
    local -A seen=()
    
    # Helper to add video
    add_video() {
        local video="$1"
        [[ -z "${seen[$video]}" ]] || return
        seen[$video]=1
        videos+=("$video")
    }
    
    # From default directory
    if [[ -d "${DEFAULT_WALLPAPER_DIR}" ]]; then
        for ext in mp4 webm mkv avi mov m4v; do
            for video in "${DEFAULT_WALLPAPER_DIR}"/*."${ext}" \
                         "${DEFAULT_WALLPAPER_DIR}"/*."${ext^^}"; do
                [[ -f "$video" ]] && add_video "$video"
            done
        done
    fi
    
    # From custom directories
    for dir in "${WATCH_DIRS[@]}"; do
        [[ -d "$dir" ]] || continue
        for ext in mp4 webm mkv avi mov m4v; do
            for video in "$dir"/*."${ext}" "$dir"/*."${ext^^}"; do
                [[ -f "$video" ]] && add_video "$video"
            done
        done
    done 2>/dev/null
    
    # Print unique videos
    printf '%s\n' "${videos[@]}"
}

count_videos() {
    get_all_videos | wc -l
}

# =============================================================================
# PyWal Integration
# =============================================================================

run_pywal() {
    local wallpaper="$1"
    
    if ! is_command wal; then
        return 1
    fi
    
    local ext="${wallpaper##*.}"
    ext="${ext,,}"
    
    case "$ext" in
        png|jpg|jpeg|gif|bmp)
            wal -i "$wallpaper" --backend theme 2>/dev/null &
            return 0
            ;;
        mp4|webm|mkv|avi|mov|m4v)
            local temp_frame
            temp_frame=$(mktemp --suffix=.png)
            if ffmpeg -y -ss 00:00:01 -i "$wallpaper" -vframes 1 "$temp_frame" 2>/dev/null; then
                wal -i "$temp_frame" --backend theme 2>/dev/null &
                rm -f "$temp_frame"
                return 0
            fi
            ;;
    esac
    
    return 1
}

cmd_pywal() {
    local current
    current=$(get_current_wallpaper)
    
    if [[ -z "$current" ]]; then
        echo -e "${ERROR}No wallpaper currently set${C_RESET}"
        return 1
    fi
    
    if ! is_command wal; then
        echo -e "${ERROR}PyWal not installed${C_RESET}"
        echo "  Install with: yay -S pywal"
        return 1
    fi
    
    echo -e "${INFO}Generating colorscheme from: $(basename "$current")${C_RESET}"
    
    if run_pywal "$current"; then
        echo -e "${SUCCESS}Colorschemed generated!${C_RESET}"
        echo "  Reload your terminal or run 'source ~/.cache/wal/colors.sh'"
    else
        echo -e "${ERROR}Failed to generate colorscheme${C_RESET}"
        return 1
    fi
}

# =============================================================================
# Startup and Auto-reload
# =============================================================================

get_last_wallpaper() {
    if [[ -f "${HISTORY_FILE}" ]]; then
        tail -n 1 "${HISTORY_FILE}" | cut -d'|' -f2
    fi
}

restore_wallpaper() {
    local wallpaper
    wallpaper=$(get_last_wallpaper)
    
    if [[ -n "$wallpaper" && -f "$wallpaper" ]]; then
        set_wallpaper "$wallpaper"
        echo -e "${INFO}Restored wallpaper: $(basename "$wallpaper")${C_RESET}"
        return 0
    fi
    
    return 1
}

watch_for_changes() {
    local wallpaper_dir="$1"
    local wallpaper_file
    
    while true; do
        sleep 5
        wallpaper_file=$(get_last_wallpaper)
        
        if [[ -n "$wallpaper_file" && ! -f "$wallpaper_file" ]]; then
            echo -e "${WARNING}Wallpaper file missing, switching to next...${C_RESET}"
            cmd_next
        fi
    done 2>/dev/null &
}

# =============================================================================
# Multi-monitor specific wallpapers
# =============================================================================

set_per_monitor() {
    local monitor="$1"
    local video="$2"
    
    if [[ ! -f "$video" ]]; then
        echo -e "${ERROR}File not found: ${video}${C_RESET}"
        return 1
    fi
    
    kill_wallpaper "$monitor"
    
    local audio_opts=""
    [[ "${ENABLE_AUDIO}" != "yes" ]] && audio_opts="no-audio"
    
    mpvpaper -fp -o "loop-file=${LOOP_MODE} ${audio_opts} video-latency-hacks=yes" \
        "$monitor" "$video" &>/dev/null &
    
    add_to_history "$video"
    
    if [[ "${NOTIFICATIONS_ENABLED}" == "yes" ]]; then
        notify-send "Wallpaper" "Set on ${monitor}: $(basename "$video")" -t 2000 2>/dev/null || true
    fi
}

cmd_set_monitor() {
    local monitor="${1:-}"
    local video="${2:-}"
    
    if [[ -z "$monitor" || -z "$video" ]]; then
        echo -e "${ERROR}Usage: wallpaper-picker set-monitor <MONITOR> <VIDEO>${C_RESET}"
        return 1
    fi
    
    set_per_monitor "$monitor" "$video"
}

# =============================================================================
# State management
# =============================================================================

save_state() {
    local current="${CURRENT_WALLPAPER:-$(get_current_wallpaper)}"
    local timestamp
    timestamp=$(date -Iseconds)
    
    cat > "${STATE_FILE}" <<EOF
{
    "current": "${current}",
    "monitor": "$(resolve_monitor)",
    "timestamp": "${timestamp}",
    "version": "${SCRIPT_VERSION}"
    "version": "${SCRIPT_VERSION}"
}
EOF
}

add_to_history() {
    local video="$1"
    local timestamp
    timestamp=$(date -Iseconds)
    
    echo "${timestamp}|${video}" >> "${HISTORY_FILE}"
    
    # Keep last 100 entries
    tail -n 100 "${HISTORY_FILE}" > "${HISTORY_FILE}.tmp" && \
        mv "${HISTORY_FILE}.tmp" "${HISTORY_FILE}"
}

is_favorite() {
    local video="$1"
    local basename
    basename=$(basename "$video")
    
    [[ -f "${FAVORITES_FILE}" ]] || return 1
    
    # Simple grep - check if basename or full path exists in favorites
    if grep -F -- "$basename" "${FAVORITES_FILE}" 2>/dev/null | grep -qF -- "$video"; then
        return 0
    fi
    if grep -qF -- "$video" "${FAVORITES_FILE}" 2>/dev/null; then
        return 0
    fi
    return 1
}

toggle_favorite() {
    local video="$1"
    
    if [[ ! -f "$video" ]]; then
        echo -e "${ERROR}Error:${C_RESET} File not found: ${video}"
        return 1
    fi
    
    if is_favorite "$video"; then
        # Remove from favorites - write all lines except matching
        local temp_file
        temp_file=$(mktemp)
        while IFS= read -r line; do
            if [[ "$line" != "$video" ]] && [[ "${line##*/}" != "${video##*/}" ]]; then
                echo "$line"
            fi
        done < "${FAVORITES_FILE}" > "$temp_file"
        mv "$temp_file" "${FAVORITES_FILE}"
        echo -e "${INFO}Removed from favorites"
        return 1
    else
        # Add to favorites
        echo "$video" >> "${FAVORITES_FILE}"
        echo -e "${SUCCESS}★ Added to favorites"
        return 0
    fi
}

# =============================================================================
# Video preview generation
# =============================================================================

generate_preview() {
    local video="$1"
    local max_width="${2:-80}"
    local max_height="${3:-30}"
    
    if ! is_command ffmpeg; then
        echo "ffmpeg not available for preview"
        return 1
    fi
    
    local temp_thumb
    temp_thumb=$(mktemp --suffix=.jpg)
    
    ffmpeg -y -ss 00:00:02 -i "$video" \
        -vframes 1 -q:v 5 \
        -vf "scale=${max_width}:${max_height}:force_original_aspect_ratio=decrease" \
        "$temp_thumb" 2>/dev/null
    
    if [[ -f "$temp_thumb" ]]; then
        cat "$temp_thumb" | base64 | fold -w ${max_width}
        rm -f "$temp_thumb"
    fi
}

preview_file() {
    local file="$1"
    local width="${COLUMNS:-80}"
    local height=$(( $(tput lines 2>/dev/null || echo 20) - 5 ))
    
    if [[ ! -f "$file" ]]; then
        echo "File not found"
        return
    fi
    
    local ext="${file##*.}"
    ext="${ext,,}"
    
    case "$ext" in
        mp4|webm|mkv|avi|mov|m4v)
            if is_command ffmpeg; then
                generate_preview "$file" "$((width / 2))" "$((height / 2))"
            else
                echo "[ Video: $ext ]"
            fi
            ;;
        png|jpg|jpeg|gif|bmp)
            if is_command chafa 2>/dev/null; then
                chafa -s "$((width/2))x$((height/2))" "$file" 2>/dev/null || echo "$file"
            elif is_command img2txt 2>/dev/null; then
                img2txt -W "$((width/2))" "$file" 2>/dev/null || echo "$file"
            else
                echo "$file"
            fi
            ;;
        *)
            echo "$file"
            ;;
    esac
}

# =============================================================================
# Smart random (avoid recent)
# =============================================================================

get_smart_random() {
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo ""
        return 1
    fi
    
    local recent=()
    if [[ -f "${HISTORY_FILE}" ]]; then
        mapfile -t recent < <(tail -n 10 "${HISTORY_FILE}" | cut -d'|' -f2)
    fi
    
    local candidates=()
    for video in "${videos[@]}"; do
        local is_recent=0
        for r in "${recent[@]}"; do
            if [[ "$video" == "$r" ]]; then
                is_recent=1
                break
            fi
        done
        if [[ $is_recent -eq 0 ]]; then
            candidates+=("$video")
        fi
    done
    
    if [[ ${#candidates[@]} -gt 0 ]]; then
        local idx=$((RANDOM % ${#candidates[@]}))
        echo "${candidates[$idx]}"
    else
        echo "${videos[$((RANDOM % ${#videos[@]}))]}"
    fi
}

# =============================================================================
# Time-based wallpaper
# =============================================================================

get_time_of_day() {
    local hour
    hour=$(date +%H)
    
    if [[ $hour -ge 6 && $hour -lt 12 ]]; then
        echo "morning"
    elif [[ $hour -ge 12 && $hour -lt 18 ]]; then
        echo "afternoon"
    elif [[ $hour -ge 18 && $hour -lt 22 ]]; then
        echo "evening"
    else
        echo "night"
    fi
}

get_time_based_video() {
    local tod
    tod=$(get_time_of_day)
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    local candidates=()
    for video in "${videos[@]}"; do
        if [[ "${video,,}" == *"${tod}"* ]]; then
            candidates+=("$video")
        fi
    done
    
    if [[ ${#candidates[@]} -gt 0 ]]; then
        echo "${candidates[$((RANDOM % ${#candidates[@]}))]}"
        return 0
    fi
    
    return 1
}

# =============================================================================
# Interactive picker (fzf)
# =============================================================================

interactive_picker() {
    require_command fzf "fzf"
    
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo -e "${ERROR}No wallpapers found!${C_RESET}"
        echo ""
        echo "  Add wallpapers to: ${DEFAULT_WALLPAPER_DIR}"
        echo "  Or use: wallpaper-picker add-dir /path/to/wallpapers"
        return 1
    fi
    
    echo -e "${C_CYAN}Loading ${#videos[@]} wallpapers...${C_RESET}"
    
    local temp_file
    temp_file=$(mktemp)
    trap "rm -f '$temp_file'" EXIT
    
    printf '%s\n' "${videos[@]}" > "$temp_file"
    
    local header="Enter: Set | Ctrl+R: Random | Ctrl+S: Smart Random | Ctrl+F: Toggle ★ | Esc: Exit"
    
    local fzf_opts=(
        --prompt="Wallpaper > "
        --height=70%
        --reverse
        --border=rounded
        --header="$header"
        --bind="ctrl-r:execute-silent(wallpaper-picker random)"
        --bind="ctrl-s:execute-silent(wallpaper-picker smart-random)"
        --bind="ctrl-f:execute-silent(echo {} > '$temp_file.wf')+reload(cat '$temp_file')"
        --bind="change:top+reload(cat {})+unbind(change)"
        --info=hidden
        --margin=1
        --color='bg+:#1a1a2e,fg+:#eeeedd,hl:#51a4ff:bold,fg:#6272a4,hl+:#51a4ff,preview-bg:#16213e'
    )
    
    if [[ "${PREVIEW_ENABLED}" == "yes" ]] && is_command ffmpeg; then
        fzf_opts+=(
            --preview-window=right:50%:hidden:wrap
            --preview="bash -c 'wallpaper-picker preview {}'"
        )
    fi
    
    local selected
    selected=$(fzf "${fzf_opts[@]}" < "$temp_file" 2>/dev/null)
    
    if [[ -n "$selected" ]]; then
        set_wallpaper "$selected"
    else
        echo -e "${INFO}Selection cancelled"
        return 1
    fi
}

cmd_preview() {
    preview_file "${1:-}"
}

set_wallpaper_from_stdin() {
    local selected
    while read -r selected; do
        [[ -n "$selected" ]] && set_wallpaper "$selected"
        break
    done
}

# =============================================================================
# File browser picker
# =============================================================================

browse_picker() {
    require_command fzf "fzf"
    
    local selected
    selected=$(find "${HOME}" -type f \( \
        -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" -o \
        -name "*.avi" -o -name "*.mov" -o -name "*.m4v" \
        \) 2>/dev/null | \
        fzf --prompt="📁 Browse videos > " \
            --height=70% \
            --reverse \
            --border \
            --margin=1)
    
    if [[ -n "$selected" ]]; then
        set_wallpaper "$selected"
    fi
}

# =============================================================================
# Slideshow management
# =============================================================================

start_slideshow() {
    local interval="${1:-${SLIDESHOW_INTERVAL}}"
    local videos=()
    
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo -e "${ERROR}No wallpapers found!${C_RESET}"
        return 1
    fi
    
    # Shuffle if enabled
    if [[ "${SLIDESHOW_SHUFFLE}" == "yes" ]]; then
        local shuffled=()
        while [[ ${#videos[@]} -gt 0 ]]; do
            local idx=$((RANDOM % ${#videos[@]}))
            shuffled+=("${videos[$idx]}")
            unset 'videos[idx]'
            videos=("${videos[@]}")
        done
        videos=("${shuffled[@]}")
    fi
    
    echo -e "${C_MAGENTA}⟳${C_RESET} Slideshow started (${#videos[@]} wallpapers, ${interval}s interval)"
    echo "  Press Ctrl+C to stop"
    
    SLIDESHOW_PID=$$
    
    while true; do
        for video in "${videos[@]}"; do
            [[ -f "$video" ]] && set_wallpaper "$video"
            sleep "$interval"
        done
    done
}

# =============================================================================
# Directory management
# =============================================================================

add_watch_directory() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        echo -e "${ERROR}Directory not found:${C_RESET} $dir"
        return 1
    fi
    
    if [[ -f "${WATCH_DIRS_FILE}" ]] && grep -qF -- "$dir" "${WATCH_DIRS_FILE}"; then
        echo -e "${WARNING}Already watching:${C_RESET} $dir"
        return 1
    fi
    
    echo "$dir" >> "${WATCH_DIRS_FILE}"
    sort -u -o "${WATCH_DIRS_FILE}" "${WATCH_DIRS_FILE}"
    
    echo -e "${SUCCESS}Added:${C_RESET} $dir"
    
    local count
    count=$(find "$dir" -type f \( -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" \) 2>/dev/null | wc -l)
    echo "  Found ${count} video files"
}

remove_watch_directory() {
    local dir="$1"
    
    if [[ -f "${WATCH_DIRS_FILE}" ]] && grep -qF -- "$dir" "${WATCH_DIRS_FILE}"; then
        grep -vF -- "$dir" "${WATCH_DIRS_FILE}" > "${WATCH_DIRS_FILE}.tmp" && \
            mv "${WATCH_DIRS_FILE}.tmp" "${WATCH_DIRS_FILE}"
        echo -e "${SUCCESS}Removed:${C_RESET} $dir"
    else
        echo -e "${ERROR}Not in watch list:${C_RESET} $dir"
        return 1
    fi
}

list_watch_directories() {
    if [[ -f "${WATCH_DIRS_FILE}" ]] && [[ -s "${WATCH_DIRS_FILE}" ]]; then
        echo -e "${C_CYAN}Watch directories:${C_RESET}"
        while IFS= read -r dir; do
            local count
            count=$(find "$dir" -type f \( -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" \) 2>/dev/null | wc -l)
            echo "  • $dir (${count} videos)"
        done < "${WATCH_DIRS_FILE}"
    else
        echo -e "${INFO}No custom watch directories${C_RESET}"
        echo "  Default: ${DEFAULT_WALLPAPER_DIR}"
    fi
}

# =============================================================================
# Systemd integration
# =============================================================================

enable_startup_service() {
    local service_dir="${HOME}/.config/systemd/user"
    local service_file="${service_dir}/wallpaper-picker.service"
    
    mkdir -p "$service_dir"
    
    cat > "$service_file" <<EOF
[Unit]
Description=Wallpaper Picker Slideshow Service
After=graphical.target

[Service]
Type=simple
ExecStart=${HOME}/.local/bin/wallpaper-picker slideshow ${SLIDESHOW_INTERVAL}
Restart=on-failure
RestartSec=5
Environment=DISPLAY=:0

[Install]
WantedBy=default.target
EOF

    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user enable --now wallpaper-picker.service 2>/dev/null || true
    
    echo -e "${SUCCESS}Slideshow service enabled${C_RESET}"
}

disable_startup_service() {
    systemctl --user disable --now wallpaper-picker.service 2>/dev/null || true
    echo -e "${INFO}Slideshow service disabled${C_RESET}"
}


    log_info "Default configuration created"
}

# =============================================================================
# Monitor functions
# =============================================================================

get_active_monitors() {
    if is_command hyprctl; then
        hyprctl monitors 2>/dev/null | grep -E "^Monitor" | awk '{print $2}' || echo "default"
    else
        echo "default"
    fi
}

get_primary_monitor() {
    local monitors
    mapfile -t monitors < <(get_active_monitors)
    
    for m in "${monitors[@]}"; do
        if [[ "$m" =~ ^(HDMI|DP|eDP) ]]; then
            echo "$m"
            return
        fi
    done
    
    echo "${monitors[0]:-default}"
}

resolve_monitor() {
    if [[ -n "${MONITOR}" ]]; then
        echo "${MONITOR}"
    else
        get_primary_monitor
    fi
}

# =============================================================================
# Wallpaper functions
# =============================================================================

kill_wallpaper() {
    local monitor="${1:-$(resolve_monitor)}"
    
    if pgrep -f "mpvpaper.*${monitor}" >/dev/null 2>&1; then
        pkill -f "mpvpaper.*${monitor}" 2>/dev/null || true
        sleep 0.2
    fi
}

set_wallpaper() {
    local video="$1"
    local monitor
    monitor=$(resolve_monitor)
    
    # Validate video exists
    if [[ ! -f "$video" ]]; then
        echo -e "${ERROR}Error:${C_RESET} File not found: ${video}"
        return 1
    fi
    
    # Kill existing
    kill_wallpaper "$monitor"
    
    # Build options
    local audio_opts=""
    [[ "${ENABLE_AUDIO}" != "yes" ]] && audio_opts="no-audio"
    
    # Start new wallpaper
    mpvpaper -fp -o "loop-file=${LOOP_MODE} ${audio_opts} video-latency-hacks=yes" \
        "$monitor" "$video" &>/dev/null &
    
    CURRENT_WALLPAPER="$video"
    save_state
    add_to_history "$video"
    
    local filename
    filename=$(basename "$video")
    echo -e "${SUCCESS} Wallpaper set: ${C_BOLD}${filename}${C_RESET}"
    
    # Notify
    if [[ "${NOTIFICATIONS_ENABLED}" == "yes" ]]; then
        notify-send "Wallpaper" "Set: ${filename}" -t 2000 2>/dev/null || true
    fi
    
    return 0
}

get_current_wallpaper() {
    # Try running process
    local current
    current=$(pgrep -a mpvpaper 2>/dev/null | grep -oE "[^ ]+\.(mp4|webm|mkv)" | head -1 || true)
    
    # Try state file
    if [[ -z "$current" ]] && [[ -f "${STATE_FILE}" ]]; then
        current=$(grep -oE '"current":\s*"[^"]+"' "${STATE_FILE}" 2>/dev/null | \
            sed 's/"current":\s*"//;s/"$//' || true)
    fi
    
    echo "$current"
}

get_random_wallpaper() {
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo ""
        return 1
    fi
    
    local random_index=$((RANDOM % ${#videos[@]}))
    echo "${videos[$random_index]}"
}

# =============================================================================
# Video discovery
# =============================================================================

get_all_videos() {
    local videos=()
    local -A seen=()
    
    # Helper to add video
    add_video() {
        local video="$1"
        [[ -z "${seen[$video]}" ]] || return
        seen[$video]=1
        videos+=("$video")
    }
    
    # From default directory
    if [[ -d "${DEFAULT_WALLPAPER_DIR}" ]]; then
        for ext in mp4 webm mkv avi mov m4v; do
            for video in "${DEFAULT_WALLPAPER_DIR}"/*."${ext}" \
                         "${DEFAULT_WALLPAPER_DIR}"/*."${ext^^}"; do
                [[ -f "$video" ]] && add_video "$video"
            done
        done
    fi
    
    # From custom directories
    for dir in "${WATCH_DIRS[@]:-}"; do
        [[ -d "$dir" ]] || continue
        for ext in mp4 webm mkv avi mov m4v; do
            for video in "$dir"/*."${ext}" "$dir"/*."${ext^^}"; do
                [[ -f "$video" ]] && add_video "$video"
            done
        done
    done
    
    # Print unique videos
    printf '%s\n' "${videos[@]}"
}

count_videos() {
    get_all_videos | wc -l
}

# =============================================================================
# State management
# =============================================================================

save_state() {
    local current="${CURRENT_WALLPAPER:-$(get_current_wallpaper)}"
    local timestamp
    timestamp=$(date -Iseconds)
    
    cat > "${STATE_FILE}" <<EOF
{
    "current": "${current}",
    "monitor": "$(resolve_monitor)",
    "timestamp": "${timestamp}",
    "version": "${SCRIPT_VERSION}"
}
EOF
}

add_to_history() {
    local video="$1"
    local timestamp
    timestamp=$(date -Iseconds)
    
    echo "${timestamp}|${video}" >> "${HISTORY_FILE}"
    
    # Keep last 100 entries
    tail -n 100 "${HISTORY_FILE}" > "${HISTORY_FILE}.tmp" && \
        mv "${HISTORY_FILE}.tmp" "${HISTORY_FILE}"
}

is_favorite() {
    local video="$1"
    local basename
    basename=$(basename "$video")
    
    [[ -f "${FAVORITES_FILE}" ]] || return 1
    
    # Simple grep - check if basename or full path exists in favorites
    if grep -F -- "$basename" "${FAVORITES_FILE}" 2>/dev/null | grep -qF -- "$video"; then
        return 0
    fi
    if grep -qF -- "$video" "${FAVORITES_FILE}" 2>/dev/null; then
        return 0
    fi
    return 1
}

toggle_favorite() {
    local video="$1"
    
    if [[ ! -f "$video" ]]; then
        echo -e "${ERROR}Error:${C_RESET} File not found: ${video}"
        return 1
    fi
    
    if is_favorite "$video"; then
        # Remove from favorites - write all lines except matching
        local temp_file
        temp_file=$(mktemp)
        while IFS= read -r line; do
            if [[ "$line" != "$video" ]] && [[ "${line##*/}" != "${video##*/}" ]]; then
                echo "$line"
            fi
        done < "${FAVORITES_FILE}" > "$temp_file"
        mv "$temp_file" "${FAVORITES_FILE}"
        echo -e "${INFO}Removed from favorites"
        return 1
    else
        # Add to favorites
        echo "$video" >> "${FAVORITES_FILE}"
        echo -e "${SUCCESS}‚ėÖ Added to favorites"
        return 0
    fi
}

# =============================================================================
# Interactive picker (fzf)
# =============================================================================

interactive_picker() {
    require_command fzf "fzf"
    
    local videos=()
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo -e "${ERROR}No wallpapers found!${C_RESET}"
        echo ""
        echo "  Add wallpapers to: ${DEFAULT_WALLPAPER_DIR}"
        echo "  Or use: wallpaper-picker add-dir /path/to/wallpapers"
        return 1
    fi
    
    echo -e "${C_CYAN}Loading ${#videos[@]} wallpapers...${C_RESET}"
    
    # Use a temp file for fzf to avoid issues with special chars
    local temp_file
    temp_file=$(mktemp)
    printf '%s\n' "${videos[@]}" > "$temp_file"
    
    # FZF options
    local fzf_opts=(
        --prompt="ūüé® Wallpaper > "
        --height=60%
        --reverse
        --border=rounded
        --header='Enter: Set | Ctrl+R: Random | Esc: Exit'
        --bind="ctrl-r:execute-silent(wallpaper-picker random)"
        --info=hidden
        --margin=1
        --color='bg+:#1a1a2e,fg+:#eeeedd,hl:#51a4ff:bold,fg:#6272a4,hl+:#51a4ff'
    )
    
    # Preview window
    if [[ "${PREVIEW_ENABLED}" == "yes" ]]; then
        fzf_opts+=(
            --preview-window=right:50%:wrap
            --preview-window=hidden
            --bind="ctrl-p:toggle-preview"
            --bind="enter:execute(wallpaper-picker set {})+accept"
            --header-lines=0
        )
    fi
    
    # Run fzf
    local selected
    selected=$(fzf "${fzf_opts[@]}" < "$temp_file")
    
    rm -f "$temp_file"
    
    if [[ -n "$selected" ]]; then
        set_wallpaper "$selected"
    else
        echo -e "${INFO}Selection cancelled"
        return 1
    fi
}

set_wallpaper_from_stdin() {
    local selected
    while read -r selected; do
        [[ -n "$selected" ]] && set_wallpaper "$selected"
        break
    done
}

# =============================================================================
# File browser picker
# =============================================================================

browse_picker() {
    require_command fzf "fzf"
    
    local selected
    selected=$(find "${HOME}" -type f \( \
        -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" -o \
        -name "*.avi" -o -name "*.mov" -o -name "*.m4v" \
        \) 2>/dev/null | \
        fzf --prompt="ūüďĀ Browse videos > " \
            --height=70% \
            --reverse \
            --border \
            --margin=1)
    
    if [[ -n "$selected" ]]; then
        set_wallpaper "$selected"
    fi
}

# =============================================================================
# Slideshow management
# =============================================================================

start_slideshow() {
    local interval="${1:-${SLIDESHOW_INTERVAL}}"
    local videos=()
    
    mapfile -t videos < <(get_all_videos)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo -e "${ERROR}No wallpapers found!${C_RESET}"
        return 1
    fi
    
    # Shuffle if enabled
    if [[ "${SLIDESHOW_SHUFFLE}" == "yes" ]]; then
        local shuffled=()
        while [[ ${#videos[@]} -gt 0 ]]; do
            local idx=$((RANDOM % ${#videos[@]}))
            shuffled+=("${videos[$idx]}")
            unset 'videos[idx]'
            videos=("${videos[@]}")
        done
        videos=("${shuffled[@]}")
    fi
    
    echo -e "${C_MAGENTA}‚ü≥${C_RESET} Slideshow started (${#videos[@]} wallpapers, ${interval}s interval)"
    echo "  Press Ctrl+C to stop"
    
    SLIDESHOW_PID=$$
    
    while true; do
        for video in "${videos[@]}"; do
            [[ -f "$video" ]] && set_wallpaper "$video"
            sleep "$interval"
        done
    done
}

# =============================================================================
# Directory management
# =============================================================================

add_watch_directory() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        echo -e "${ERROR}Directory not found:${C_RESET} $dir"
        return 1
    fi
    
    if [[ -f "${WATCH_DIRS_FILE}" ]] && grep -qF -- "$dir" "${WATCH_DIRS_FILE}"; then
        echo -e "${WARNING}Already watching:${C_RESET} $dir"
        return 1
    fi
    
    echo "$dir" >> "${WATCH_DIRS_FILE}"
    sort -u -o "${WATCH_DIRS_FILE}" "${WATCH_DIRS_FILE}"
    
    echo -e "${SUCCESS}Added:${C_RESET} $dir"
    
    local count
    count=$(find "$dir" -type f \( -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" \) 2>/dev/null | wc -l)
    echo "  Found ${count} video files"
}

remove_watch_directory() {
    local dir="$1"
    
    if [[ -f "${WATCH_DIRS_FILE}" ]] && grep -qF -- "$dir" "${WATCH_DIRS_FILE}"; then
        grep -vF -- "$dir" "${WATCH_DIRS_FILE}" > "${WATCH_DIRS_FILE}.tmp" && \
            mv "${WATCH_DIRS_FILE}.tmp" "${WATCH_DIRS_FILE}"
        echo -e "${SUCCESS}Removed:${C_RESET} $dir"
    else
        echo -e "${ERROR}Not in watch list:${C_RESET} $dir"
        return 1
    fi
}

list_watch_directories() {
    if [[ -f "${WATCH_DIRS_FILE}" ]] && [[ -s "${WATCH_DIRS_FILE}" ]]; then
        echo -e "${C_CYAN}Watch directories:${C_RESET}"
        while IFS= read -r dir; do
            local count
            count=$(find "$dir" -type f \( -name "*.mp4" -o -name "*.webm" -o -name "*.mkv" \) 2>/dev/null | wc -l)
            echo "  ‚ÄĘ $dir (${count} videos)"
        done < "${WATCH_DIRS_FILE}"
    else
        echo -e "${INFO}No custom watch directories${C_RESET}"
        echo "  Default: ${DEFAULT_WALLPAPER_DIR}"
    fi
}

# =============================================================================
# Systemd integration
# =============================================================================

enable_startup_service() {
    local service_dir="${HOME}/.config/systemd/user"
    local service_file="${service_dir}/wallpaper-picker.service"
    
    mkdir -p "$service_dir"
    
    cat > "$service_file" <<EOF
[Unit]
Description=Wallpaper Picker Slideshow Service
After=graphical.target

[Service]
Type=simple
ExecStart=${HOME}/.local/bin/wallpaper-picker slideshow ${SLIDESHOW_INTERVAL}
Restart=on-failure
RestartSec=5
Environment=DISPLAY=:0

[Install]
WantedBy=default.target
EOF

    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user enable --now wallpaper-picker.service 2>/dev/null || true
    
    echo -e "${SUCCESS}Slideshow service enabled${C_RESET}"
}

disable_startup_service() {
    systemctl --user disable --now wallpaper-picker.service 2>/dev/null || true
    echo -e "${INFO}Slideshow service disabled${C_RESET}"
}


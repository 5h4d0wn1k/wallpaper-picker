# =============================================================================
# Logging functions
# =============================================================================

log() {
    local level="${1:-INFO}"
    local message="${2:-}"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${timestamp}] [${level}] ${message}" >> "${LOG_FILE}" 2>/dev/null || true
    
    if [[ "$level" == "ERROR" || "$level" == "WARN" ]]; then
        echo -e "${ERROR}[${level}]${C_RESET} ${message}" >&2
    fi
}

log_info() { log "INFO" "$1"; }
log_warn() { log "WARN" "$1"; }
log_error() { log "ERROR" "$1"; }

# =============================================================================
# Signal handlers
# =============================================================================

cleanup() {
    if [[ -n "${SLIDESHOW_PID}" ]] && kill -0 "${SLIDESHOW_PID}" 2>/dev/null; then
        kill "${SLIDESHOW_PID}" 2>/dev/null || true
    fi
}

trap cleanup EXIT INT TERM

# =============================================================================
# Utility functions
# =============================================================================

is_command() {
    command -v "$1" >/dev/null 2>&1
}

require_command() {
    local cmd="$1"
    local pkg="${2:-$cmd}"
    
    if ! is_command "$cmd"; then
        echo -e "${ERROR}Error:${C_RESET} Required command not found: ${cmd}"
        echo "       Install with: sudo pacman -S ${pkg}"
        echo "       Or for AUR packages: yay -S ${pkg}"
        exit 1
    fi
}

check_dependencies() {
    local missing=()
    
    is_command mpvpaper || missing+=("mpvpaper")
    is_command fzf || missing+=("fzf")
    is_command mpv || missing+=("mpv")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${WARNING}Warning:${C_RESET} Missing dependencies:"
        for dep in "${missing[@]}"; do
            echo "  ‚ÄĘ ${dep}"
        done
        return 1
    fi
    return 0
}

# =============================================================================
# Configuration management
# =============================================================================

load_config() {
    if [[ ! -f "${CONFIG_FILE}" ]]; then
        create_default_config
    fi
    
    # Source config (safely handle spaces and special chars)
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        [[ -z "$value" ]] && continue
        
        # Remove quotes and trim
        value="${value#\"}"
        value="${value%\"}"
        value="${value#\'}"
        value="${value%\'}"
        value="${value%"${value##*[![:space:]]}"}"
        
        case "$key" in
            MONITOR) MONITOR="$value" ;;
            AUTO_DETECT_MONITOR) AUTO_DETECT_MONITOR="$value" ;;
            DEFAULT_WALLPAPER_DIR) DEFAULT_WALLPAPER_DIR="$value" ;;
            ENABLE_AUDIO) ENABLE_AUDIO="$value" ;;
            LOOP_MODE) LOOP_MODE="$value" ;;
            SLIDESHOW_INTERVAL) SLIDESHOW_INTERVAL="$value" ;;
            SLIDESHOW_SHUFFLE) SLIDESHOW_SHUFFLE="$value" ;;
            THUMBNAIL_ENABLED) THUMBNAIL_ENABLED="$value" ;;
            CACHE_THUMBNAILS) CACHE_THUMBNAILS="$value" ;;
            NOTIFICATIONS_ENABLED) NOTIFICATIONS_ENABLED="$value" ;;
            PREVIEW_ENABLED) PREVIEW_ENABLED="$value" ;;
            PREVIEW_TIMEOUT) PREVIEW_TIMEOUT="$value" ;;
            STARTUP_MODE) STARTUP_MODE="$value" ;;
        esac
    done < "${CONFIG_FILE}"
    
    # Load watch directories
    if [[ -f "${WATCH_DIRS_FILE}" ]]; then
        mapfile -t WATCH_DIRS < "${WATCH_DIRS_FILE}"
    fi
}


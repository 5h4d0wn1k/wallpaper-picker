# =============================================================================

cmd_pick() {
    interactive_picker
}

cmd_browse() {
    browse_picker
}

cmd_random() {
    local video
    video=$(get_random_wallpaper)
    
    if [[ -n "$video" ]]; then
        set_wallpaper "$video"
    else
        echo -e "${ERROR}No wallpapers found!${C_RESET}"
        return 1
    fi
}

cmd_slideshow() {
    start_slideshow "${1:-}"
}

cmd_stop() {
    kill_wallpaper
    echo -e "${INFO}Wallpaper stopped${C_RESET}"
}

cmd_current() {
    local current
    current=$(get_current_wallpaper)
    
    if [[ -n "$current" ]]; then
        echo -e "${C_CYAN}Current wallpaper:${C_RESET}"
        echo "  File:     $(basename "$current")"
        echo "  Path:     $current"
        echo "  Monitor:  $(resolve_monitor)"
        
        if is_favorite "$current"; then
            echo -e "  Favorite: ${C_YELLOW}‚ėÖ${C_RESET}"
        fi
    else
        echo -e "${INFO}No wallpaper currently set${C_RESET}"
    fi
}

cmd_next() {
    local videos=()
    local current
    local next_idx=0
    
    mapfile -t videos < <(get_all_videos)
    current=$(get_current_wallpaper)
    
    for i in "${!videos[@]}"; do
        if [[ "${videos[$i]}" == "$current" ]]; then
            next_idx=$(( (i + 1) % ${#videos[@]} ))
            break
        fi
    done
    
    set_wallpaper "${videos[$next_idx]}"
}

cmd_prev() {
    local videos=()
    local current
    local prev_idx=0
    
    mapfile -t videos < <(get_all_videos)
    current=$(get_current_wallpaper)
    
    for i in "${!videos[@]}"; do
        if [[ "${videos[$i]}" == "$current" ]]; then
            prev_idx=$(( (i - 1 + ${#videos[@]}) % ${#videos[@]} ))
            break
        fi
    done
    
    set_wallpaper "${videos[$prev_idx]}"
}

cmd_list() {
    local videos=()
    local count=1
    local current
    
    mapfile -t videos < <(get_all_videos)
    current=$(get_current_wallpaper)
    
    if [[ ${#videos[@]} -eq 0 ]]; then
        echo -e "${INFO}No wallpapers found${C_RESET}"
        return 1
    fi
    
    echo -e "${C_CYAN}Available wallpapers (${#videos[@]}):${C_RESET}"
    echo ""
    
    for video in "${videos[@]}"; do
        local basename="${video##*/}"
        
        if [[ "$video" == "$current" ]]; then
            echo -e "  ${C_GREEN}‚Ė∂${C_RESET} ${count}. ${basename} ${C_DIM}(current)${C_RESET}"
        elif is_favorite "$video"; then
            echo -e "  ${C_YELLOW}‚ėÖ${C_RESET} ${count}. ${basename}"
        else
            echo "    ${count}. ${basename}"
        fi
        ((count++))
    done
}

cmd_add_dir() {
    add_watch_directory "${1:-}"
}

cmd_remove_dir() {
    remove_watch_directory "${1:-}"
}

cmd_watch_dirs() {
    list_watch_directories
}

cmd_toggle_fav() {
    local video="${1:-$(get_current_wallpaper)}"
    toggle_favorite "$video"
}

cmd_config() {
    ${EDITOR:-nano} "${CONFIG_FILE}"
}

cmd_monitors() {
    echo -e "${C_CYAN}Available monitors:${C_RESET}"
    while IFS= read -r m; do
        echo "  ‚ÄĘ $m"
    done < <(get_active_monitors)
    echo ""
    echo "  Active: $(resolve_monitor)"
}

cmd_doctor() {
    echo -e "${C_BOLD}Wallpaper Picker Doctor${C_RESET}"
    echo ""
    
    local issues=0
    
    # Dependencies
    echo -e "${C_CYAN}Checking dependencies...${C_RESET}"
    
    for cmd in mpvpaper fzf mpv; do
        if is_command "$cmd"; then
            echo -e "  ${C_GREEN}‚úď${C_RESET} ${cmd}"
        else
            echo -e "  ${C_RED}‚úó${C_RESET} ${cmd}"
            issues=$((issues + 1))
        fi
    done
    
    # ffprobe is optional
    if is_command ffprobe; then
        echo -e "  ${C_GREEN}‚úď${C_RESET} ffprobe (optional)"
    else
        echo -e "  ${C_YELLOW}!${C_RESET} ffprobe (optional, for previews)"
    fi
    
    echo ""
    
    # Directories
    echo -e "${C_CYAN}Checking directories...${C_RESET}"
    
    if [[ -d "${DEFAULT_WALLPAPER_DIR}" ]]; then
        local count
        count=$(count_videos)
        echo -e "  ${C_GREEN}‚úď${C_RESET} ${DEFAULT_WALLPAPER_DIR} (${count} videos)"
    else
        echo -e "  ${C_YELLOW}!${C_RESET} ${DEFAULT_WALLPAPER_DIR} (not found)"
        echo "    Run: mkdir -p ${DEFAULT_WALLPAPER_DIR}"
    fi
    
    # Running status
    echo ""
    echo -e "${C_CYAN}Checking wallpaper status...${C_RESET}"
    
    if pgrep -x mpvpaper >/dev/null 2>&1; then
        echo -e "  ${C_GREEN}‚úď${C_RESET} mpvpaper is running"
    else
        echo -e "  ${C_INFO}‚óč${C_RESET} No wallpaper running"
    fi
    
    echo ""
    
    if [[ $issues -eq 0 ]]; then
        echo -e "${C_GREEN}All checks passed!${C_RESET}"
    else
        echo -e "${C_YELLOW}${issues} issue(s) found${C_RESET}"
    fi
}

cmd_status() {
    echo -e "${C_BOLD}Wallpaper Picker Status${C_RESET}"
    echo ""
    
    echo -e "${C_CYAN}Configuration:${C_RESET}"
    echo "  Monitor:      $(resolve_monitor)"
    echo "  Default dir:  ${DEFAULT_WALLPAPER_DIR}"
    echo "  Audio:        ${ENABLE_AUDIO}"
    echo "  Loop mode:    ${LOOP_MODE}"
    echo "  Slideshow:    ${SLIDESHOW_INTERVAL}s interval"
    
    echo ""
    echo -e "${C_CYAN}Statistics:${C_RESET}"
    echo "  Total wallpapers: $(count_videos)"
    echo "  Watch dirs:       ${#WATCH_DIRS[@]}"
    echo "  History entries:  $(wc -l < "${HISTORY_FILE}" 2>/dev/null || echo 0)"
    echo "  Favorites:        $(wc -l < "${FAVORITES_FILE}" 2>/dev/null || echo 0)"
    
    echo ""
    cmd_current
}

cmd_enable_startup() {
    enable_startup_service
}

cmd_disable_startup() {
    disable_startup_service
}

cmd_gui() {
    if [[ -x "${HOME}/.local/bin/wallpaper-picker-gui" ]]; then
        exec "${HOME}/.local/bin/wallpaper-picker-gui" "$@"
    else
        echo -e "${ERROR}GUI not installed${C_RESET}"
        echo "  The GUI component requires GTK4 and Python"
        echo "  Install with: wallpaper-picker install-gui"
        return 1
    fi
}

cmd_install_gui() {
    echo -e "${C_BOLD}Installing GUI dependencies...${C_RESET}"
    echo ""
    
    local missing=()
    
    # Check GTK4
    if ! python3 -c "import gi; gi.require_version('Gtk', '4.0')" 2>/dev/null; then
        missing+=("gtk4")
    fi
    
    # Check PyGObject
    if ! python3 -c "import gi" 2>/dev/null; then
        missing+=("python-gobject")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Install with:"
        echo "  sudo pacman -S ${missing[*]}"
    else
        echo -e "${SUCCESS}GUI dependencies satisfied${C_RESET}"
        echo "  Run 'wallpaper-picker gui' to launch the GUI"
    fi
}


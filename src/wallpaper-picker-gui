__version__ = "2.2.0"

CONFIG_DIR = Path.home() / ".config" / "wallpaper-picker"
STATE_FILE = CONFIG_DIR / "state.json"
MONITOR_CONFIG_FILE = CONFIG_DIR / "monitor-layout.json"
FAVORITES_FILE = Path.home() / ".local" / "share" / "wallpaper-picker" / "favorites"
HISTORY_FILE = Path.home() / ".local" / "share" / "wallpaper-picker" / "history"
CACHE_DIR = Path.home() / ".cache" / "wallpaper-picker"


def get_config():
    config = {
        "MONITOR": "",
        "DEFAULT_DIR": str(Path.home() / "Videos" / "wallpapers"),
        "ENABLE_AUDIO": "no",
        "SLIDESHOW_INTERVAL": "30",
        "SPAN_MODE": "scaled",
    }
    
    config_file = CONFIG_DIR / "config"
    if config_file.exists():
        with open(config_file) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith('#') and '=' in line:
                    key, _, value = line.partition('=')
                    config[key.strip()] = value.strip().strip('"')
    
    return config


def get_monitors_info():
    """Get detailed monitor information from Hyprland"""
    try:
        result = subprocess.run(
            ["hyprctl", "monitors", "-j"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            return json.loads(result.stdout)
    except:
        pass
    return []


def get_primary_monitor():
    monitors = get_monitors_info()
    if monitors:
        for m in monitors:
            if any(x in m.get("name", "") for x in ['HDMI', 'DP', 'eDP']):
                return m.get("name")
        return monitors[0].get("name")
    return "default"


def load_monitor_layout():
    """Load saved monitor layout configuration"""
    if MONITOR_CONFIG_FILE.exists():
        with open(MONITOR_CONFIG_FILE) as f:
            return json.load(f)
    return {"monitors": [], "spanning": {}}


def save_monitor_layout(layout):
    """Save monitor layout configuration"""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(MONITOR_CONFIG_FILE, 'w') as f:
        json.dump(layout, f, indent=2)


def get_all_videos(config):
    videos = []
    dirs_to_scan = [Path(config.get("DEFAULT_DIR", str(Path.home() / "Videos" / "wallpapers")))]
    
    watch_dirs = CONFIG_DIR / "watch-dirs"
    if watch_dirs.exists():
        with open(watch_dirs) as f:
            for line in f:
                path = Path(line.strip())
                if path.exists():
                    dirs_to_scan.append(path)
    
    extensions = {'.mp4', '.webm', '.mkv', '.avi', '.mov', '.m4v', '.png', '.jpg', '.jpeg', '.gif', '.bmp'}
    
    for directory in dirs_to_scan:
        if directory.exists():
            for ext in extensions:
                videos.extend(directory.glob(f"*{ext}"))
                videos.extend(directory.glob(f"*{ext.upper()}"))
    
    return sorted(set(videos), key=lambda x: x.name.lower())


def generate_thumbnail(video_path, size=(320, 180)):
    cache_dir = CACHE_DIR / "thumbnails"
    cache_dir.mkdir(parents=True, exist_ok=True)
    
    hash_name = hashlib.md5(str(video_path).encode()).hexdigest()
    thumbnail_path = cache_dir / f"{hash_name}.jpg"
    
    if thumbnail_path.exists():
        return str(thumbnail_path)
    
    try:
        ext = video_path.suffix.lower()
        if ext in {'.mp4', '.webm', '.mkv', '.avi', '.mov', '.m4v'}:
            subprocess.run([
                "ffmpeg", "-y", "-ss", "00:00:02", "-i", str(video_path),
                "-vframes", "1", "-q:v", "3", "-s", f"{size[0]}x{size[1]}",
                str(thumbnail_path)
            ], capture_output=True, timeout=15)
        elif ext in {'.png', '.jpg', '.jpeg', '.gif', '.bmp'}:
            subprocess.run([
                "convert", "-resize", f"{size[0]}x{size[1]}", str(video_path), str(thumbnail_path)
            ], capture_output=True, timeout=10)
        
        if thumbnail_path.exists():
            return str(thumbnail_path)
    except:
        pass
    
    return None


def get_video_duration(video_path):
    try:
        result = subprocess.run([
            "ffprobe", "-v", "error",
            "-show_entries", "format=duration",
            "-of", "csv=p=0", str(video_path)
        ], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            return float(result.stdout.strip() or 0)
    except:
        pass
    return 0


def set_wallpaper(video_path, monitor="", audio="no", span_mode="scaled"):
    """Set wallpaper with multi-monitor support"""
    monitors = get_monitors_info() if not monitor else [{"name": monitor}]
    
    if span_mode == "scaled" or not monitors:
        monitor = monitor or get_primary_monitor()
        audio_opt = "" if audio == "yes" else "no-audio"
        
        subprocess.run(["pkill", "-f", f"mpvpaper.*{monitor}"], capture_output=True)
        
        def run_wp():
            subprocess.Popen([
                "mpvpaper", "-fp", "-o",
                f"loop-file=inf {audio_opt} video-latency-hacks=yes",
                monitor, str(video_path)
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        threading.Thread(target=run_wp, daemon=True).start()
    else:
        set_spanning_wallpaper(video_path, monitors, audio)
    
    save_state(video_path, monitors[0].get("name") if monitors else "default")


def set_spanning_wallpaper(video_path, monitors, audio="no"):
    """Set wallpaper spanning across multiple monitors"""
    audio_opt = "" if audio == "yes" else "no-audio"
    
    subprocess.run(["pkill", "-f", "mpvpaper"], capture_output=True)
    
    # For each monitor, set the same video
    for monitor in monitors:
        name = monitor.get("name", "default")
        threading.Thread(target=lambda m=name: subprocess.Popen([
            "mpvpaper", "-fp", "-o",
            f"loop-file=inf {audio_opt} video-latency-hacks=yes",
            m, str(video_path)
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).wait(), daemon=True).start()


def save_state(video_path, monitor):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATE_FILE, 'w') as f:
        json.dump({
            "current": str(video_path),
            "monitor": monitor,
        }, f)


class MonitorCanvas(Gtk.DrawingArea):
    """Interactive monitor layout canvas with drag and drop"""
    
    def __init__(self, monitors, on_layout_changed):
        super().__init__()
        self.monitors = monitors
        self.on_layout_changed = on_layout_changed
        self.dragging_monitor = None
        self.drag_offset_x = 0
        self.drag_offset_y = 0
        self.padding = 40
        self.scale = 0.3
        
        self.set_draw_func(self.draw_canvas)
        self.set_size_request(400, 300)
        
        # Enable mouse events using GTK4 event controllers
        click = Gtk.GestureClick()
        click.connect("pressed", self.on_button_press)
        click.connect("released", self.on_button_release)
        self.add_controller(click)
        
        motion = Gtk.EventControllerMotion()
        motion.connect("motion", self.on_motion)
        self.add_controller(motion)
    
    def draw_canvas(self, area, cr, width, height):
        """Draw the monitor layout"""
        cr.set_source_rgb(0.1, 0.1, 0.15)
        cr.paint()
        
        if not self.monitors:
            cr.set_source_rgb(0.5, 0.5, 0.5)
            cr.select_font_face("Sans", cairo.FontSlant.NORMAL, cairo.FontWeight.NORMAL)
            cr.set_font_size(12)
            cr.show_text("No monitors detected")
            return
        
        # Calculate bounds
        min_x = min(m.get("x", 0) for m in self.monitors)
        min_y = min(m.get("y", 0) for m in self.monitors)
        max_x = max(m.get("x", 0) + m.get("width", 1920) for m in self.monitors)
        max_y = max(m.get("y", 0) + m.get("height", 1080) for m in self.monitors)
        
        total_w = max_x - min_x
        total_h = max_y - min_y
        
        # Calculate scale to fit
        available_w = width - 2 * self.padding
        available_h = height - 2 * self.padding
        scale_x = available_w / total_w if total_w > 0 else 1
        scale_y = available_h / total_h if total_h > 0 else 1
        self.scale = min(scale_x, scale_y, 0.5) * 0.9
        
        offset_x = self.padding + (available_w - total_w * self.scale) / 2
        offset_y = self.padding + (available_h - total_h * self.scale) / 2
        
        # Draw monitors
        for monitor in self.monitors:
            x = (monitor.get("x", 0) - min_x) * self.scale + offset_x
            y = (monitor.get("y", 0) - min_y) * self.scale + offset_y
            w = monitor.get("width", 1920) * self.scale
            h = monitor.get("height", 1080) * self.scale
            
            # Monitor body
            if self.dragging_monitor == monitor:
                cr.set_source_rgb(0.3, 0.3, 0.5)
            else:
                cr.set_source_rgb(0.2, 0.25, 0.35)
            cr.rectangle(x, y, w, h)
            cr.fill()
            
            # Border
            cr.set_source_rgb(0.4, 0.5, 0.7)
            cr.set_line_width(2)
            cr.rectangle(x, y, w, h)
            cr.stroke()
            
            # Monitor name
            name = monitor.get("name", "Unknown")
            cr.set_source_rgb(0.9, 0.9, 0.95)
            cr.select_font_face("Sans", cairo.FontSlant.NORMAL, cairo.FontWeight.NORMAL)
            cr.set_font_size(10)
            cr.move_to(x + 5, y + 15)
            cr.show_text(name)
            
            # Resolution
            res = f"{monitor.get('width', 1920)}x{monitor.get('height', 1080)}"
            cr.move_to(x + 5, y + 28)
            cr.show_text(res)
            
            # Store calculated position
            monitor["_draw_x"] = x
            monitor["_draw_y"] = y
            monitor["_draw_w"] = w
            monitor["_draw_h"] = h
    
    def on_button_press(self, gesture, n_press, x, y):
        """Handle mouse button press"""
        for monitor in reversed(self.monitors):
            dx = monitor.get("_draw_x", 0)
            dy = monitor.get("_draw_y", 0)
            dw = monitor.get("_draw_w", 0)
            dh = monitor.get("_draw_h", 0)
            
            if dx <= x <= dx + dw and dy <= y <= dy + dh:
                self.dragging_monitor = monitor
                self.drag_offset_x = x - dx
                self.drag_offset_y = y - dy
                self.queue_draw()
                return True
        
        return False
    
    def on_motion(self, controller, x, y):
        """Handle mouse motion"""
        if self.dragging_monitor:
            self.queue_draw()
            return True
        return False
    
    def on_button_release(self, gesture, n_press, x, y):
        """Handle mouse button release"""
        if self.dragging_monitor:
            self.dragging_monitor = None
            self.queue_draw()
            if self.on_layout_changed:
                self.on_layout_changed(self.monitors)
            return True
        return False


class WallpaperPickerGUI(Adw.Application):
    def __init__(self):
        super().__init__(application_id='com.wallpaperpicker.app')
        self.config = get_config()
        self.monitors = get_monitors_info()
        self.videos = get_all_videos(self.config)
        self.filtered_videos = self.videos.copy()
        self.current_video = None
        self.selected_monitor = get_primary_monitor()
        self.span_mode = "scaled"
        self.monitor_layout = load_monitor_layout()
        
        self.connect('activate', self.on_activate)
    
    def on_activate(self, app):
        self.setup_window()
        self.window.present()
    
    def setup_window(self):
        self.window = Gtk.ApplicationWindow(application=self)
        self.window.set_title("Wallpaper Picker")
        self.window.set_default_size(1200, 800)
        
        # Main split view
        split_view = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        split_view.set_resize_start_child(True)
        split_view.set_shrink_start_child(False)
        split_view.set_position(800)
        self.window.set_child(split_view)
        
        # Left panel - Video Grid
        left_panel = self.create_video_panel()
        split_view.set_start_child(left_panel)
        
        # Right panel - Settings & Monitor Layout
        right_panel = self.create_settings_panel()
        split_view.set_end_child(right_panel)
    
    def create_video_panel(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        
        # Header
        header = Adw.HeaderBar()
        header.set_title_widget(Gtk.Label(label="<b>Wallpapers</b>"))
        
        refresh_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        refresh_btn.set_tooltip_text("Refresh")
        refresh_btn.connect("clicked", lambda *_: self.load_videos())
        header.pack_start(refresh_btn)
        
        box.append(header)
        
        # Search
        search_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        search_box.set_margin_start(12)
        search_box.set_margin_end(12)
        search_box.set_margin_top(12)
        box.append(search_box)
        
        self.search_entry = Gtk.SearchEntry()
        self.search_entry.set_placeholder_text("Search wallpapers...")
        self.search_entry.set_hexpand(True)
        self.search_entry.connect("search-changed", lambda *_: self.load_videos())
        search_box.append(self.search_entry)
        
        self.fav_toggle = Gtk.ToggleButton(icon_name="star-outline-symbolic")
        self.fav_toggle.set_tooltip_text("Show favorites only")
        self.fav_toggle.connect("toggled", lambda *_: self.load_videos())
        search_box.append(self.fav_toggle)
        
        # Grid
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scrolled.set_vexpand(True)
        box.append(scrolled)
        
        self.flow_box = Gtk.FlowBox()
        self.flow_box.set_valign(Gtk.Align.START)
        self.flow_box.set_max_children_per_line(30)
        self.flow_box.set_min_children_per_line(3)
        self.flow_box.set_homogeneous(True)
        self.flow_box.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.flow_box.set_row_spacing(8)
        self.flow_box.set_column_spacing(8)
        self.flow_box.connect("child-activated", self.on_video_activated)
        scrolled.set_child(self.flow_box)
        
        # Status
        self.status_label = Gtk.Label()
        self.status_label.add_css_class("dim-label")
        self.status_label.set_margin_start(12)
        self.status_label.set_margin_end(12)
        self.status_label.set_margin_bottom(12)
        box.append(self.status_label)
        
        self.load_videos()
        return box
    
    def create_settings_panel(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_start(12)
        box.set_margin_end(12)
        box.set_margin_top(12)
        
        # Monitor Layout Section
        monitor_section = Adw.PreferencesGroup(title="Monitor Layout")
        box.append(monitor_section)
        
        # Monitor Canvas
        self.monitor_canvas = MonitorCanvas(self.monitors, self.on_layout_changed)
        canvas_frame = Adw.Clamp(maximum_size=400)
        canvas_frame.set_child(self.monitor_canvas)
        monitor_section.add(canvas_frame)
        
        # Monitor Info
        info_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        for m in self.monitors:
            label = Gtk.Label()
            label.set_markup(f"<b>{m.get('name', 'Unknown')}</b>: {m.get('width', 0)}x{m.get('height', 0)} @ ({m.get('x', 0)}, {m.get('y', 0)})")
            label.set_halign(Gtk.Align.START)
            info_box.append(label)
        monitor_section.add(info_box)
        
        # Span Mode
        span_group = Adw.PreferencesGroup(title="Spanning Mode")
        box.append(span_group)
        
        mode_combo = Gtk.DropDown()
        mode_store = Gtk.StringList()
        mode_store.append("Same wallpaper on all (scaled)")
        mode_store.append("Spanning across monitors")
        mode_store.append("Different per monitor")
        mode_combo.set_model(mode_store)
        mode_combo.connect("notify::selected", self.on_span_mode_changed)
        span_group.add(mode_combo)
        
        # Monitor Selector
        monitor_group = Adw.PreferencesGroup(title="Active Monitor")
        box.append(monitor_group)
        
        self.monitor_combo = Gtk.DropDown()
        monitor_store = Gtk.StringList()
        for m in self.monitors:
            name = m.get("name", "default")
            res = f"{m.get('width', 0)}x{m.get('height', 0)}"
            monitor_store.append(f"{name} ({res})")
        self.monitor_combo.set_model(monitor_store)
        self.monitor_combo.connect("notify::selected", self.on_monitor_selected)
        monitor_group.add(self.monitor_combo)
        
        # Preview Section
        preview_group = Adw.PreferencesGroup(title="Preview")
        box.append(preview_group)
        
        self.preview_image = Gtk.Picture()
        self.preview_image.set_size_request(320, 180)
        self.preview_image.set_halign(Gtk.Align.CENTER)
        self.preview_image.set_valign(Gtk.Align.CENTER)
        preview_group.add(self.preview_image)
        
        self.preview_label = Gtk.Label()
        self.preview_label.set_halign(Gtk.Align.CENTER)
        preview_group.add(self.preview_label)
        
        # Audio Toggle
        audio_group = Adw.PreferencesGroup(title="Audio")
        box.append(audio_group)
        
        audio_row = Adw.ActionRow(title="Enable Audio")
        self.audio_switch = Gtk.Switch()
        audio_row.add_suffix(self.audio_switch)
        audio_group.add(audio_row)
        
        # Apply Button
        apply_btn = Gtk.Button(label="Apply Wallpaper")
        apply_btn.add_css_class("suggested-action")
        apply_btn.set_margin_top(12)
        apply_btn.connect("clicked", self.on_apply)
        box.append(apply_btn)
        
        # Add scrolled wrapper
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_child(box)
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        
        return scrolled
    
    def on_layout_changed(self, monitors):
        """Save layout when monitors are rearranged"""
        self.monitor_layout = {"monitors": monitors}
        save_monitor_layout(self.monitor_layout)
    
    def on_span_mode_changed(self, combo, param):
        """Handle span mode change"""
        index = combo.get_selected()
        modes = ["scaled", "spanning", "individual"]
        self.span_mode = modes[index] if index < len(modes) else "scaled"
    
    def on_monitor_selected(self, combo, param):
        """Handle monitor selection"""
        index = combo.get_selected()
        if index < len(self.monitors):
            self.selected_monitor = self.monitors[index].get("name", "default")
    
    def on_video_activated(self, flow_box, child):
        """Handle video selection"""
        index = child.get_index()
        if 0 <= index < len(self.filtered_videos):
            video = self.filtered_videos[index]
            self.current_video = video
            self.show_preview(video)
    
    def show_preview(self, video_path):
        """Show video preview"""
        thumb = generate_thumbnail(video_path)
        if thumb:
            self.preview_image.set_filename(thumb)
        else:
            self.preview_image.set_icon_name("video-x-generic-symbolic")
        
        self.preview_label.set_text(video_path.name)
    
    def on_apply(self, button):
        """Apply the selected wallpaper"""
        if not self.current_video:
            return
        
        audio = "yes" if self.audio_switch.get_active() else "no"
        set_wallpaper(self.current_video, self.selected_monitor, audio, self.span_mode)
        
        # Show notification
        toast = Adw.Toast(title=f"Wallpaper set: {self.current_video.name}")
        toast.set_timeout(2)
        
        # Try to show toast via notify-send
        subprocess.run([
            "notify-send", "-i", "wallpaper-picker",
            "Wallpaper Set", f"Applied: {self.current_video.name}"
        ], capture_output=True)
    
    def load_videos(self):
        """Load and filter videos"""
        while child := self.flow_box.get_first_child():
            self.flow_box.remove(child)
        
        search = self.search_entry.get_text().lower()
        favorites_only = self.fav_toggle.get_active()
        
        favorites = set()
        if FAVORITES_FILE.exists():
            with open(FAVORITES_FILE) as f:
                favorites = {line.strip() for line in f if line.strip()}
        
        self.filtered_videos = []
        for video in self.videos:
            if search and search not in video.name.lower():
                continue
            if favorites_only and str(video) not in favorites and video.name not in favorites:
                continue
            self.filtered_videos.append(video)
        
        for video in self.filtered_videos:
            card = self.create_video_card(video)
            self.flow_box.append(card)
        
        total = len(self.videos)
        shown = len(self.filtered_videos)
        self.status_label.set_text(f"Showing {shown} of {total} wallpapers")
    
    def create_video_card(self, video_path):
        """Create video thumbnail card"""
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.add_css_class("card")
        box.set_valign(Gtk.Align.START)
        
        # Thumbnail
        thumb = Gtk.Picture()
        thumb.set_size_request(160, 90)
        thumb.set_can_shrink(True)
        thumb.set_halign(Gtk.Align.CENTER)
        
        GLib.idle_add(self.load_thumbnail, video_path, thumb)
        box.append(thumb)
        
        # Label
        name_label = Gtk.Label(label=video_path.stem)
        name_label.set_max_width_chars(20)
        name_label.set_ellipsize(3)
        name_label.add_css_class("caption")
        name_label.set_halign(Gtk.Align.CENTER)
        box.append(name_label)
        
        return box
    
    def load_thumbnail(self, video_path, picture):
        """Load thumbnail for video"""
        thumb = generate_thumbnail(video_path, (160, 90))
        if thumb:
            picture.set_filename(thumb)


def main():
    if not HAS_GTK:
        print("GTK4 and libadwaita are required for GUI mode")
        print("Install: sudo pacman -S gtk4 libadwaita python-gobject")
        sys.exit(1)
    
    app = WallpaperPickerGUI()
    return app.run(None)


if __name__ == "__main__":
    sys.exit(main())
